# Binaries for programs and plugins
**/*.exe
**/*.exe~
**/*.dll
**/*.so
**/*.dylib
**/bin

# Test binary, built with `go test -c`
**/*.test

# Output of the go coverage tool
**/*.out

# Dependency directories
**/node_modules
**/vendor

# SQLite databases
**/*.db
**/*.db-journal
**/*.sqlite
**/*.sqlite3
**/stories.db

# Frontend build outputs
**/dist
**/dist-ssr
**/build

# Editor directories and files
**/.idea
**/.vscode
**/*.swp
**/*.swo
**/.DS_Store
**/.env
**/.env.local

# Logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# Git
.git
.github
.gitignore

# Fly (no longer used)
fly.toml
